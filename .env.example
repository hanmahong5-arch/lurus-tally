# ── Required — service cannot start without these ──────────────────────────────

# Local dev DSN matching docker-compose.dev.yml postgres credentials (tally/tallysecret).
# Include search_path=tally so every query targets the correct schema automatically.
DATABASE_DSN=postgres://tally:tallysecret@localhost:5432/lurus?sslmode=disable&search_path=tally

# Redis DB 5 is reserved for tally per lurus.yaml Redis DB allocation.
REDIS_URL=redis://localhost:6379/5

# NATS JetStream; stream PSI_EVENTS is auto-created on service boot.
NATS_URL=nats://localhost:4222

# ── Optional — sensible defaults for local development ─────────────────────────

# HTTP listen port; K8s readiness probe and Service targetPort both expect 18200.
PORT=18200

# Log verbosity: debug | info | warn | error. Use debug locally; info in prod.
LOG_LEVEL=info

# Gin framework mode: debug (colorful request log) | release (minimal, prod-safe).
GIN_MODE=debug

# Build version label injected by CI via -ldflags; leave as "dev" locally.
SERVICE_VERSION=dev

# Graceful shutdown deadline. Increase to 30s in prod for long-running requests.
SHUTDOWN_TIMEOUT=5s

# Set to true to run golang-migrate on service startup (embedded migrations).
# Set to false when you prefer manual `make migrate-up` control.
MIGRATE_ON_BOOT=true

# ── Cross-service dependencies ─────────────────────────────────────────────────

# Bearer key for calls to platform-core; required for identity and billing features.
# The platform-core service validates this key on all /internal/v1/ routes.
INTERNAL_API_KEY=dev-placeholder

# Platform-core internal URL. In K8s: platform-core.lurus-platform.svc:18104.
# Leave empty locally if you are not running platform-core; billing calls will error.
PLATFORM_URL=http://platform-core.lurus-platform.svc:18104

# Lurus Hub API key for LLM inference (natural language queries, AI assistant).
# Leave blank to disable AI features; the service starts normally without this.
HUB_TOKEN=

# Kova agent execution REST endpoint. Leave blank to disable agent features.
KOVA_URL=

# AI memory engine URL. Cluster default shown; leave as-is for K8s, override locally.
MEMORUS_URL=http://memorus.lurus-system.svc:8880

# ── Authentication (Zitadel OIDC) ─────────────────────────────────────────────

# Zitadel OIDC issuer domain. JWTs issued by auth.lurus.cn are trusted by this service.
ZITADEL_DOMAIN=auth.lurus.cn

# OIDC client ID for this service (confidential client registered in Zitadel).
# Create via Zitadel console: Applications → New → Web → Confidential.
ZITADEL_CLIENT_ID=

# Expected `aud` claim in Zitadel-issued JWTs. Typically matches the client ID.
JWT_AUDIENCE=

# ── Horticulture seed data ──────────────────────────────────────────────────────

# Set to true to load 200 nursery species into tally.nursery_dict on startup.
# Uses ON CONFLICT DO NOTHING — safe to re-run (idempotent).
# DO NOT set in automated CI environments; seed rows are visible to all tenants.
SEED_NURSERY_DICT=false # set true to load 200 nursery species on startup
