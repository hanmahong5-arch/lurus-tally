# =============================================================================
# Tally Web — environment variables template
# Copy to .env.local for local development. Never commit .env.local.
# =============================================================================

# NextAuth secret (generate with: openssl rand -base64 32)
AUTH_SECRET=

# OIDC identity provider (vendor-neutral) — production auth.
# Endpoints are resolved via <issuer>/.well-known/openid-configuration discovery,
# so only the client id, issuer (and optional client secret) are configured here.
# Inject real per-environment values at deploy time; do not bind to a vendor URL.
OIDC_CLIENT_ID=
OIDC_ISSUER=https://identity.lurus.cn
# OIDC_CLIENT_SECRET=  # optional; only when the provider requires confidential client auth

# Backend service URL (in-cluster or local)
BACKEND_URL=http://localhost:18200

# NextAuth base URL (used in production / staging)
NEXTAUTH_URL=http://localhost:3000

# =============================================================================
# E2E / UAT only — DO NOT set in production.
# Enables the offline Credentials provider for Playwright sessions.
# Both AUTH_DEV_PROVIDER=true AND NODE_ENV != production must be true;
# setting this in production is refused with a console.error and is a no-op.
# =============================================================================
# AUTH_DEV_PROVIDER=true
