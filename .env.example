# ── Required — service cannot start without these ──────────────────────────────

# Local dev DSN matching docker-compose.dev.yml postgres credentials (tally/tallysecret).
# Include search_path=tally so every query targets the correct schema automatically.
DATABASE_DSN=postgres://tally:tallysecret@localhost:5432/lurus?sslmode=disable&search_path=tally

# Redis DB 5 is reserved for tally per lurus.yaml Redis DB allocation.
REDIS_URL=redis://localhost:6379/5

# NATS JetStream; stream PSI_EVENTS is auto-created on service boot.
NATS_URL=nats://localhost:4222

# ── Optional — sensible defaults for local development ─────────────────────────

# HTTP listen port; K8s readiness probe and Service targetPort both expect 18200.
PORT=18200

# Log verbosity: debug | info | warn | error. Use debug locally; info in prod.
LOG_LEVEL=info

# Gin framework mode: debug (colorful request log) | release (minimal, prod-safe).
GIN_MODE=debug

# Build version label injected by CI via -ldflags; leave as "dev" locally.
SERVICE_VERSION=dev

# Graceful shutdown deadline. Increase to 30s in prod for long-running requests.
SHUTDOWN_TIMEOUT=5s

# Set to true to run golang-migrate on service startup (embedded migrations).
# Set to false when you prefer manual `make migrate-up` control.
MIGRATE_ON_BOOT=true

# ── Cross-service dependencies ─────────────────────────────────────────────────

# Bearer key for calls to platform-core; required for identity and billing features.
# The platform-core service validates this key on all /internal/v1/ routes.
INTERNAL_API_KEY=dev-placeholder

# Platform-core internal URL. In K8s: platform-core.lurus-platform.svc:18104.
# Leave empty locally if you are not running platform-core; billing calls will error.
PLATFORM_URL=http://platform-core.lurus-platform.svc:18104

# Lurus Hub API key for LLM inference (natural language queries, AI assistant).
# Leave blank to disable AI features; the service starts normally without this.
HUB_TOKEN=

# Kova agent execution REST endpoint. Leave blank to disable agent features.
KOVA_URL=

# AI memory engine (memorus-r) base URL. Must include the /api/v1 prefix — the
# client joins paths by concatenation. Blank MEMORUS_API_KEY disables memory
# (AI still works without recall). config.go reads MEMORUS_BASE_URL.
MEMORUS_BASE_URL=http://memorus-r.lurus-system.svc:8880/api/v1
MEMORUS_API_KEY=

# ── Authentication (vendor-neutral OIDC) ─────────────────────────────────────

# OIDC issuer. May be a bare host or a full https:// URL. JWTs issued by
# identity.lurus.cn (the canonical issuer since 2026-05-21; auth.lurus.cn is now
# a 301 alias) are trusted here. Injected per-environment — never bind to a
# specific IdP vendor's instance URL in code.
OIDC_ISSUER=identity.lurus.cn

# OIDC client ID for this service (confidential client registered with the IdP).
# Create via the provider console: Applications → New → Web → Confidential.
OIDC_CLIENT_ID=

# Expected `aud` claim in the IdP-issued JWTs. Typically matches the client ID.
OIDC_AUDIENCE=

# JWKS endpoint path appended to the issuer. Should come from discovery
# (<issuer>/.well-known/openid-configuration jwks_uri); overridable per provider.
OIDC_JWKS_PATH=/oauth/v2/keys

# ── Horticulture seed data ──────────────────────────────────────────────────────

# Set to true to load 200 nursery species into tally.nursery_dict on startup.
# Uses ON CONFLICT DO NOTHING — safe to re-run (idempotent).
# DO NOT set in automated CI environments; seed rows are visible to all tenants.
SEED_NURSERY_DICT=false # set true to load 200 nursery species on startup

# ── Chinese IM group-bot notifications (optional) ───────────────────────────────
# See internal/adapter/notify/doc.go for wiring instructions. All three are
# independently optional — leave any/all blank to disable that provider.
# None of these are read by internal/pkg/config/config.go yet (not wired into
# the DI graph); a future change plugs them into lifecycle/app.go once the
# concurrent WIP touching that file lands.

# WeCom (企业微信) group-bot webhook URL. Create via group chat → 添加机器人 →
# 自定义机器人 → copy the "Webhook 地址".
TALLY_NOTIFY_WECOM_WEBHOOK=

# DingTalk (钉钉) group-bot webhook URL and, if the bot has "加签" (signing)
# enabled, its secret (starts with "SEC"). Leave TALLY_NOTIFY_DINGTALK_SECRET
# blank if the bot uses a different security option (e.g. IP allowlist).
TALLY_NOTIFY_DINGTALK_WEBHOOK=
TALLY_NOTIFY_DINGTALK_SECRET=

# Feishu (飞书) custom-bot webhook URL. Create via group chat → 设置 → 群机器人
# → 添加机器人 → 自定义机器人.
TALLY_NOTIFY_FEISHU_WEBHOOK=
