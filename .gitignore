# Binaries
tally-backend
tally-backend.exe
*.exe
/bin/*
!/bin/*.sh
!/bin/*.md

# Claude Code local working state (agents, worktrees, transcripts) —
# except workflows/ (committed automation artifacts, UAT runner) and
# skills/tally-dev/ (dev handbook shipped alongside the source, ADR-0029 D7).
.claude/*
!.claude/workflows/
!.claude/skills/
.claude/skills/*
!.claude/skills/tally-dev/

# Go build artifacts
*.out
coverage.out

# Environment secrets — never commit real values
.env

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Vendor (dependencies managed by go modules)
vendor/

# Test cache
/tmp/

# Frontend build artifacts
web/.next/
web/node_modules/
web/.env*.local
server
_uat-reports/evidence/
